{
  "lexicon": 1,
  "id": "at.nightbo.bookmark",
  "description": "A reader's saved-for-later mark on an article. One record per (reader, article) pair; rkey is the article's TID so add/remove/move are O(1).",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["article", "folderPath", "createdAt"],
        "properties": {
          "article":    { "type": "string", "format": "at-uri" },
          "folderPath": { "type": "string", "maxLength": 255, "description": "User-defined folder, e.g. '/' or '/to-read'." },
          "createdAt":  { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
