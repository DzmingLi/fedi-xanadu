{
  "lexicon": 1,
  "id": "at.nightbo.publication",
  "description": "A Medium-style content channel (专栏). Owned by a single DID (the record author). Multi-editor support is achieved via bilateral handshake: the owner lists members here, and each member creates a at.nightbo.publication.membership record under their own DID to confirm.",
  "defs": {
    "main": {
      "type": "record",
      "key": "literal:{slug}",
      "record": {
        "type": "object",
        "required": ["slug", "title", "createdAt"],
        "properties": {
          "slug": {
            "type": "string",
            "format": "at-identifier",
            "maxLength": 64,
            "description": "URL-safe identifier, [a-zA-Z0-9_-], used as the rkey."
          },
          "title": {
            "type": "unknown",
            "description": "Locale-keyed title map, e.g. {\"en\": \"AI Weekly\", \"zh\": \"AI 周刊\"}."
          },
          "description": {
            "type": "unknown",
            "description": "Locale-keyed description map."
          },
          "coverUrl": { "type": "string", "format": "uri" },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["did", "role"],
              "properties": {
                "did": { "type": "string", "format": "did" },
                "role": { "type": "string", "enum": ["owner", "editor", "writer"] }
              }
            }
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
