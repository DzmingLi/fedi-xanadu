{
  "lexicon": 1,
  "id": "at.nightbo.skilltree",
  "description": "A curated DAG of tags that expresses a learner's (or author's) roadmap through a domain. Edges are parent→child relationships; prereqs are hard/soft dependencies on top of the hierarchy. Any structural edit re-puts the whole record so external AppViews always see a consistent snapshot. rkey is the tree's TID.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "edges", "prereqs", "createdAt"],
        "properties": {
          "title":       { "type": "string", "maxLength": 500 },
          "description": { "type": "string", "maxLength": 10000 },
          "tagId":       { "type": "string", "maxLength": 64, "description": "Root tag of this tree, if any." },
          "forkedFrom":  { "type": "string", "format": "at-uri", "description": "If this tree is a fork, the original tree's at-uri." },
          "edges": {
            "type": "array",
            "description": "Parent→child tag edges forming the tree hierarchy.",
            "items": {
              "type": "object",
              "required": ["parent", "child"],
              "properties": {
                "parent": { "type": "string", "maxLength": 64 },
                "child":  { "type": "string", "maxLength": 64 }
              }
            }
          },
          "prereqs": {
            "type": "array",
            "description": "Cross-edge prerequisites that don't follow the parent/child hierarchy.",
            "items": {
              "type": "object",
              "required": ["from", "to", "prereqType"],
              "properties": {
                "from":       { "type": "string", "maxLength": 64 },
                "to":         { "type": "string", "maxLength": 64 },
                "prereqType": { "type": "string", "enum": ["required", "recommended"] }
              }
            }
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
