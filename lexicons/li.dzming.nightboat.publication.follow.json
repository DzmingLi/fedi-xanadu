{
  "lexicon": 1,
  "id": "li.dzming.nightboat.publication.follow",
  "description": "A follower's subscription record — one per (follower, publication) pair. Written under the follower's DID.",
  "defs": {
    "main": {
      "type": "record",
      "key": "literal:{slug}",
      "record": {
        "type": "object",
        "required": ["publicationSlug", "createdAt"],
        "properties": {
          "publicationUri": { "type": "string", "format": "at-uri" },
          "publicationSlug": { "type": "string", "maxLength": 64 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
